{
  "appId": "com.lavexus.familyapp",
  "appName": "Family",
  "webDir": "www",
  "server": {
    "url": "https://family-app-roan.vercel.app/app.html"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": false,
      "backgroundColor": "#fffaf5",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": false
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_family",
      "iconColor": "#ff5e14"
    }
  },
  "android": {
    "allowMixedContent": false
  }
}
